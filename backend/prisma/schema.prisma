// Prisma schema for Inventory Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}


model License {
  id          String   @id @default(uuid()) @db.Char(36)
  type        String   @db.VarChar(50)
  itemLimit   Int
  maxUsers    Int
  expiryDate  DateTime?
  purchasedAt DateTime @default(now())
  users       User[]
  @@map("Licenses")
}

model User {
  id        String   @id @default(uuid()) @db.Char(36)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(255)
  role      String   @db.VarChar(50)
  createdAt DateTime @default(now())
  licenseId String?  @db.Char(36)
  license   License? @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  items             Item[]
  transactions      Transaction[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  @@map("Users")
}

model ExpenseCategory {
  id            String    @id @default(uuid()) @db.Char(36)
  name          String    @db.VarChar(100)
  description   String?   @db.VarChar(255)
  monthlyBudget Decimal?  @db.Decimal(10, 2)
  isRecurring   Boolean   @default(false)
  userId        String    @db.Char(36)
  user          User      @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  expenses      Expense[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@map("ExpenseCategories")
}

model Expense {
  id          String          @id @default(uuid()) @db.Char(36)
  categoryId  String          @db.Char(36)
  category    ExpenseCategory @relation(fields: [categoryId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  amount      Decimal         @db.Decimal(10, 2)
  vendor      String?         @db.VarChar(255)
  description String?         @db.VarChar(500)
  expenseDate DateTime
  isRecurring Boolean         @default(false)
  userId      String          @db.Char(36)
  user        User            @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@map("Expenses")
}

model Item {
  id                String   @id @default(uuid()) @db.Char(36)
  sku               String   @unique @db.VarChar(255)
  name              String   @db.VarChar(255)
  description       String?  @db.Text
  barcode           String   @db.VarChar(255)
  quantity          Int      @default(0)
  price             Decimal  @db.Decimal(10, 2)
  category          String   @db.VarChar(100)
  manufacturingDate DateTime?
  expiryDate        DateTime?
  serialNumber      String?  @db.VarChar(255)
  location          String   @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Pricing & profit fields (Phase 2)
  purchasePrice     Decimal? @db.Decimal(10, 2)
  salePriceRetail   Decimal? @db.Decimal(10, 2)
  mrp               Decimal? @db.Decimal(10, 2)
  gstRate           String?  @db.VarChar(10)
  profitPercentage  Decimal? @db.Decimal(5, 2)
  marginAmount      Decimal? @db.Decimal(10, 2)

  userId String @db.Char(36)
  user   User   @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  transactions Transaction[]
  @@map("Items")
}

model Transaction {
  id               String   @id @default(uuid()) @db.Char(36)
  type             String   @db.VarChar(50)
  quantity         Int
  price            Decimal  @db.Decimal(10, 2)
  totalAmount      Decimal  @db.Decimal(12, 2)
  referenceNo      String   @db.VarChar(255)
  transactionDate  DateTime
  supplierOrBuyer  String   @db.VarChar(255)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  // Financial fields (Phase 2)
  gstRate           String?  @db.VarChar(10)
  gstAmount         Decimal? @db.Decimal(10, 2)
  discountPercentage Decimal? @db.Decimal(5, 2)
  discountAmount    Decimal? @db.Decimal(10, 2)
  netAmount         Decimal? @db.Decimal(12, 2)
  paymentMethod     String?  @db.VarChar(50)

  userId String @db.Char(36)
  user   User   @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  itemId String @db.Char(36)
  item   Item   @relation(fields: [itemId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  @@map("Transactions")
}
